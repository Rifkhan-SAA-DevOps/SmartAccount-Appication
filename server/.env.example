NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartledger?schema=public"
JWT_SECRET="change-this-long-random-secret-for-production"
JWT_EXPIRES_IN="7d"
APP_URL="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# AWS / S3 document storage
AWS_REGION="ap-south-1"
S3_UPLOAD_BUCKET="your-smartledger-documents-bucket"
# Optional: use CloudFront or custom domain for public file URLs
S3_PUBLIC_BASE_URL=""
S3_SIGNED_URL_EXPIRES_SECONDS="300"
MAX_UPLOAD_MB="10"

# Platform/SaaS owner admin login for /saas-admin
# Change these before production deployment.
PLATFORM_ADMIN_EMAIL="owner@smartledger.local"
PLATFORM_ADMIN_PASSWORD="ChangeMe@12345"

# Email reminder foundation. Leave blank to only log emails without sending.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="SmartLedger <no-reply@smartledger.local>"

# WhatsApp reminder foundation uses wa.me links in this version.
WHATSAPP_MODE="link"
