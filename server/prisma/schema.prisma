generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  EXPIRED
}

enum UserRoleName {
  OWNER
  ADMIN
  ACCOUNTANT
  CASHIER
  INVENTORY_MANAGER
  SALES_STAFF
  VIEWER
  AUDITOR
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

enum GrnStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum ReturnStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHEQUE
  ONLINE
  CREDIT
}

enum PaymentDirection {
  IN
  OUT
}

enum BankTransactionType {
  OPENING_BALANCE
  EXPENSE
  CUSTOMER_RECEIPT
  SUPPLIER_PAYMENT
  OWNER_DEPOSIT
  OWNER_WITHDRAWAL
  BANK_TRANSFER_IN
  BANK_TRANSFER_OUT
  ADJUSTMENT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum StockMovementType {
  OPENING
  PURCHASE
  SALE
  SALES_RETURN
  PURCHASE_RETURN
  ADJUSTMENT
  TRANSFER
  MANUFACTURING
}

model SubscriptionPlan {
  id                      String   @id @default(uuid())
  name                    String
  code                    String   @unique
  monthlyPrice            Decimal  @default(0) @db.Decimal(12, 2)
  maxUsers                Int      @default(1)
  maxProducts             Int      @default(20)
  maxInvoicesPerMonth     Int      @default(30)
  maxBranches             Int      @default(1)
  allowPos                Boolean  @default(false)
  allowInventory          Boolean  @default(true)
  allowReports            Boolean  @default(true)
  allowAdvancedReports    Boolean  @default(false)
  allowApi                Boolean  @default(false)
  allowMultiWarehouse     Boolean  @default(false)
  allowApprovals          Boolean  @default(false)
  allowManufacturing      Boolean  @default(false)
  allowBatchTracking      Boolean  @default(false)
  allowServiceJobs        Boolean  @default(false)
  allowCrm                Boolean  @default(false)
  allowQuotations         Boolean  @default(false)
  allowHrPayroll          Boolean  @default(false)
  allowProjects           Boolean  @default(false)
  allowInstallments       Boolean  @default(false)
  allowBankReconciliation Boolean  @default(false)
  allowFixedAssets        Boolean  @default(false)
  allowMultiCurrency      Boolean  @default(false)
  allowLoyalty            Boolean  @default(false)
  allowDelivery           Boolean  @default(false)
  allowBudgeting          Boolean  @default(false)
  allowCampaigns          Boolean  @default(false)
  allowDashboardBuilder   Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id                  String    @id @default(uuid())
  tenantId            String    @unique
  planId              String
  status              String    @default("trial")
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])
}

model Tenant {
  id           String       @id @default(uuid())
  name         String
  code         String       @unique
  businessType String       @default("shop")
  email        String?
  phone        String?
  status       TenantStatus @default(TRIAL)
  logoUrl      String?
  currency     String       @default("LKR")
  timezone     String       @default("Asia/Colombo")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  subscription              TenantSubscription?
  users                     User[]
  branches                  Branch[]
  customers                 Customer[]
  suppliers                 Supplier[]
  categories                ProductCategory[]
  units                     Unit[]
  products                  Product[]
  warehouses                Warehouse[]
  productStocks             ProductStock[]
  stockTransfers            StockTransfer[]
  invoices                  Invoice[]
  purchaseOrders            PurchaseOrder[]
  grns                      GoodsReceivedNote[]
  salesReturns              SalesReturn[]
  purchaseReturns           PurchaseReturn[]
  payments                  Payment[]
  expenses                  Expense[]
  bankAccounts              BankAccount[]
  bankTransactions          BankTransaction[]
  ledgerAccounts            LedgerAccount[]
  journalEntries            JournalEntry[]
  settings                  TenantSetting?
  taxRates                  TaxRate[]
  documents                 BusinessDocument[]
  audits                    AuditLog[]
  approvalRules             ApprovalRule[]
  approvalRequests          ApprovalRequest[]
  notifications             Notification[]
  reminderSetting           ReminderSetting?
  communicationLogs         CommunicationLog[]
  cheques                   Cheque[]
  chequeEvents              ChequeEvent[]
  productSerials            ProductSerial[]
  serialEvents              ProductSerialEvent[]
  warrantyClaims            WarrantyClaim[]
  manufacturingRecipes      ManufacturingRecipe[]
  manufacturingOrders       ManufacturingOrder[]
  productBatches            ProductBatch[]
  batchEvents               ProductBatchEvent[]
  serviceCatalogItems       ServiceCatalogItem[]
  serviceAppointments       ServiceAppointment[]
  serviceJobs               ServiceJob[]
  serviceJobEvents          ServiceJobEvent[]
  crmStages                 CrmPipelineStage[]
  crmLeads                  CrmLead[]
  crmActivities             CrmLeadActivity[]
  quotations                Quotation[]
  salesOrders               SalesOrder[]
  employees                 Employee[]
  attendanceRecords         AttendanceRecord[]
  salaryAdvances            SalaryAdvance[]
  payrollRuns               PayrollRun[]
  payrollItems              PayrollItem[]
  leaveRequests             LeaveRequest[]
  projects                  Project[]
  projectTasks              ProjectTask[]
  projectTaskComments       ProjectTaskComment[]
  projectTaskActivities     ProjectTaskActivity[]
  installmentPlans          InstallmentPlan[]
  installmentSchedules      InstallmentSchedule[]
  installmentPayments       InstallmentPayment[]
  bankStatements            BankStatement[]
  bankStatementLines        BankStatementLine[]
  bankReconciliationMatches BankReconciliationMatch[]
  bankReconciliations       BankReconciliation[]
  fixedAssets               FixedAsset[]
  fixedAssetDepreciations   FixedAssetDepreciation[]
  fixedAssetMaintenances    FixedAssetMaintenance[]
  currencies                Currency[]
  exchangeRates             ExchangeRate[]
  currencyRevaluations      CurrencyRevaluation[]
  loyaltyTiers              LoyaltyTier[]
  loyaltyRules              LoyaltyRule[]
  loyaltyAccounts           LoyaltyAccount[]
  loyaltyTransactions       LoyaltyTransaction[]
  rewardVouchers            RewardVoucher[]
  deliveryOrders            DeliveryOrder[]
  deliveryEvents            DeliveryEvent[]
  budgets                   Budget[]
  budgetLines               BudgetLine[]
  forecastScenarios         ForecastScenario[]
  cashFlowForecastLines     CashFlowForecastLine[]
  campaignTemplates         CampaignTemplate[]
  marketingCampaigns        MarketingCampaign[]
  campaignRecipients        CampaignRecipient[]
  dashboardLayouts          DashboardLayout[]
  dashboardWidgets          DashboardWidget[]
  dashboardShortcuts        DashboardShortcut[]
  loginHistories            LoginHistory[]
  trustedDevices            TrustedDevice[]
  securityEvents            SecurityEvent[]
}

model TenantSetting {
  id                 String   @id @default(uuid())
  tenantId           String   @unique
  legalName          String?
  address            String?
  taxNumber          String?
  website            String?
  invoicePrefix      String   @default("INV")
  receiptPrefix      String   @default("REC")
  invoiceTemplate    String   @default("modern")
  invoiceAccentColor String   @default("#7c3aed")
  invoiceFooter      String?  @default("Thank you for your business.")
  invoiceTerms       String?  @default("Payment is due according to the agreed terms.")
  showLogo           Boolean  @default(true)
  showTaxNumber      Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TaxRate {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  rate      Decimal  @default(0) @db.Decimal(5, 2)
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model User {
  id           String       @id @default(uuid())
  tenantId     String
  name         String
  email        String       @unique
  passwordHash String
  role         UserRoleName @default(ADMIN)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices          Invoice[]         @relation("InvoiceCreatedBy")
  audits            AuditLog[]
  approvalRequests  ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalDecisions ApprovalRequest[] @relation("ApprovalDecidedBy")
  notifications     Notification[]
  loginHistories    LoginHistory[]
  trustedDevices    TrustedDevice[]
  securityEvents    SecurityEvent[]

  @@index([tenantId])
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  code      String
  address   String?
  phone     String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouses Warehouse[]
  invoices   Invoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Customer {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  phone          String?
  email          String?
  address        String?
  groupName      String?  @default("Retail")
  creditLimit    Decimal  @default(0) @db.Decimal(12, 2)
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  currencyCode   String   @default("LKR")
  foreignBalance Decimal  @default(0) @db.Decimal(12, 2)
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 6)
  loyalty        Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices            Invoice[]
  payments            Payment[]
  salesReturns        SalesReturn[]
  cheques             Cheque[]
  productSerials      ProductSerial[]
  warrantyClaims      WarrantyClaim[]
  serviceAppointments ServiceAppointment[]
  serviceJobs         ServiceJob[]
  crmLeads            CrmLead[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  installmentPlans    InstallmentPlan[]
  installmentPayments InstallmentPayment[]
  loyaltyAccount      LoyaltyAccount?
  loyaltyTransactions LoyaltyTransaction[]
  rewardVouchers      RewardVoucher[]
  deliveryOrders      DeliveryOrder[]
  campaignRecipients  CampaignRecipient[]

  @@index([tenantId])
  @@index([tenantId, phone])
}

model Supplier {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  phone          String?
  email          String?
  address        String?
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  currencyCode   String   @default("LKR")
  foreignBalance Decimal  @default(0) @db.Decimal(12, 2)
  exchangeRate   Decimal  @default(1) @db.Decimal(18, 6)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments        Payment[]
  purchaseOrders  PurchaseOrder[]
  grns            GoodsReceivedNote[]
  purchaseReturns PurchaseReturn[]
  cheques         Cheque[]
  productSerials  ProductSerial[]
  productBatches  ProductBatch[]
  fixedAssets     FixedAsset[]

  @@index([tenantId])
}

model ProductCategory {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
}

model Unit {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  symbol    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, symbol])
}

model Warehouse {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String?
  name      String
  code      String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                    Branch?                    @relation(fields: [branchId], references: [id])
  stocks                    ProductStock[]
  productSerials            ProductSerial[]
  manufacturingOrders       ManufacturingOrder[]
  manufacturingOrderInputs  ManufacturingOrderInput[]
  manufacturingOrderOutputs ManufacturingOrderOutput[]
  productBatches            ProductBatch[]
  transfersFrom             StockTransfer[]            @relation("TransferFromWarehouse")
  transfersTo               StockTransfer[]            @relation("TransferToWarehouse")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model Product {
  id           String   @id @default(uuid())
  tenantId     String
  categoryId   String?
  unitId       String?
  sku          String?
  barcode      String?
  name         String
  description  String?
  costPrice    Decimal  @default(0) @db.Decimal(12, 2)
  salePrice    Decimal  @default(0) @db.Decimal(12, 2)
  stockQty     Decimal  @default(0) @db.Decimal(12, 3)
  reorderLevel Decimal  @default(0) @db.Decimal(12, 3)
  trackSerial  Boolean  @default(false)
  trackExpiry  Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category                  ProductCategory?           @relation(fields: [categoryId], references: [id])
  unit                      Unit?                      @relation(fields: [unitId], references: [id])
  items                     InvoiceItem[]
  purchaseOrderItems        PurchaseOrderItem[]
  grnItems                  GoodsReceivedNoteItem[]
  salesReturnItems          SalesReturnItem[]
  purchaseReturnItems       PurchaseReturnItem[]
  movements                 StockMovement[]
  warehouseStocks           ProductStock[]
  transferItems             StockTransferItem[]
  serials                   ProductSerial[]
  warrantyClaims            WarrantyClaim[]
  recipeOutputs             ManufacturingRecipe[]      @relation("RecipeOutputProduct")
  recipeInputs              ManufacturingRecipeItem[]
  manufacturingInputs       ManufacturingOrderInput[]
  manufacturingOutputs      ManufacturingOrderOutput[]
  manufacturingOutputOrders ManufacturingOrder[]       @relation("ManufacturingOutputProduct")
  batches                   ProductBatch[]
  serviceJobLines           ServiceJobLine[]
  quotationItems            QuotationItem[]
  salesOrderItems           SalesOrderItem[]
  deliveryItems             DeliveryOrderItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, barcode])
}

model StockMovement {
  id              String            @id @default(uuid())
  tenantId        String
  productId       String
  warehouseId     String?
  batchId         String?
  fromWarehouseId String?
  toWarehouseId   String?
  type            StockMovementType
  quantity        Decimal           @db.Decimal(12, 3)
  unitCost        Decimal           @default(0) @db.Decimal(12, 2)
  refType         String?
  refId           String?
  notes           String?
  createdAt       DateTime          @default(now())

  product Product       @relation(fields: [productId], references: [id])
  batch   ProductBatch? @relation(fields: [batchId], references: [id])

  @@index([tenantId, productId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, batchId])
  @@index([tenantId, createdAt])
}

model ProductStock {
  id           String   @id @default(uuid())
  tenantId     String
  productId    String
  warehouseId  String
  quantity     Decimal  @default(0) @db.Decimal(12, 3)
  reorderLevel Decimal  @default(0) @db.Decimal(12, 3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([tenantId, productId, warehouseId])
  @@index([tenantId, warehouseId])
  @@index([tenantId, productId])
}

model StockTransfer {
  id              String   @id @default(uuid())
  tenantId        String
  transferNo      String
  fromWarehouseId String
  toWarehouseId   String
  status          String   @default("POSTED")
  transferDate    DateTime @default(now())
  notes           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse           @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  items         StockTransferItem[]

  @@unique([tenantId, transferNo])
  @@index([tenantId, transferDate])
  @@index([tenantId, fromWarehouseId])
  @@index([tenantId, toWarehouseId])
}

model StockTransferItem {
  id              String  @id @default(uuid())
  stockTransferId String
  productId       String
  qty             Decimal @db.Decimal(12, 3)
  unitCost        Decimal @default(0) @db.Decimal(12, 2)

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([stockTransferId])
  @@index([productId])
}

model Invoice {
  id             String        @id @default(uuid())
  tenantId       String
  branchId       String?
  customerId     String?
  createdById    String
  invoiceNo      String
  status         InvoiceStatus @default(UNPAID)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  paid           Decimal       @default(0) @db.Decimal(12, 2)
  balance        Decimal       @default(0) @db.Decimal(12, 2)
  currencyCode   String        @default("LKR")
  exchangeRate   Decimal       @default(1) @db.Decimal(18, 6)
  foreignTotal   Decimal       @default(0) @db.Decimal(12, 2)
  foreignBalance Decimal       @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id])
  customer            Customer?            @relation(fields: [customerId], references: [id])
  createdBy           User                 @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items               InvoiceItem[]
  payments            Payment[]
  salesReturns        SalesReturn[]
  installmentPlans    InstallmentPlan[]
  loyaltyTransactions LoyaltyTransaction[]
  rewardVouchers      RewardVoucher[]
  deliveryOrders      DeliveryOrder[]

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, issueDate])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  qty         Decimal @db.Decimal(12, 3)
  costPrice   Decimal @default(0) @db.Decimal(12, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id           String         @id @default(uuid())
  tenantId     String
  supplierId   String?
  purchaseNo   String
  status       PurchaseStatus @default(ORDERED)
  orderDate    DateTime       @default(now())
  expectedDate DateTime?
  subtotal     Decimal        @default(0) @db.Decimal(12, 2)
  discount     Decimal        @default(0) @db.Decimal(12, 2)
  tax          Decimal        @default(0) @db.Decimal(12, 2)
  total        Decimal        @default(0) @db.Decimal(12, 2)
  currencyCode String         @default("LKR")
  exchangeRate Decimal        @default(1) @db.Decimal(18, 6)
  foreignTotal Decimal        @default(0) @db.Decimal(12, 2)
  notes        String?
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier?           @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  grns     GoodsReceivedNote[]

  @@unique([tenantId, purchaseNo])
  @@index([tenantId, orderDate])
  @@index([tenantId, supplierId])
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  productId       String?
  description     String
  qty             Decimal @db.Decimal(12, 3)
  unitCost        Decimal @db.Decimal(12, 2)
  discount        Decimal @default(0) @db.Decimal(12, 2)
  total           Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])
}

model GoodsReceivedNote {
  id              String    @id @default(uuid())
  tenantId        String
  supplierId      String?
  purchaseOrderId String?
  grnNo           String
  status          GrnStatus @default(POSTED)
  receivedDate    DateTime  @default(now())
  subtotal        Decimal   @default(0) @db.Decimal(12, 2)
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  tax             Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @default(0) @db.Decimal(12, 2)
  paid            Decimal   @default(0) @db.Decimal(12, 2)
  balance         Decimal   @default(0) @db.Decimal(12, 2)
  currencyCode    String    @default("LKR")
  exchangeRate    Decimal   @default(1) @db.Decimal(18, 6)
  foreignTotal    Decimal   @default(0) @db.Decimal(12, 2)
  foreignBalance  Decimal   @default(0) @db.Decimal(12, 2)
  notes           String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier?               @relation(fields: [supplierId], references: [id])
  purchaseOrder   PurchaseOrder?          @relation(fields: [purchaseOrderId], references: [id])
  items           GoodsReceivedNoteItem[]
  payments        Payment[]
  purchaseReturns PurchaseReturn[]
  productBatches  ProductBatch[]

  @@unique([tenantId, grnNo])
  @@index([tenantId, receivedDate])
  @@index([tenantId, supplierId])
}

model GoodsReceivedNoteItem {
  id              String    @id @default(uuid())
  grnId           String
  productId       String?
  description     String
  qty             Decimal   @db.Decimal(12, 3)
  unitCost        Decimal   @db.Decimal(12, 2)
  discount        Decimal   @default(0) @db.Decimal(12, 2)
  total           Decimal   @db.Decimal(12, 2)
  batchNo         String?
  manufactureDate DateTime?
  expiryDate      DateTime?

  grn     GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  product Product?          @relation(fields: [productId], references: [id])
}

model SalesReturn {
  id           String       @id @default(uuid())
  tenantId     String
  invoiceId    String?
  customerId   String?
  returnNo     String
  status       ReturnStatus @default(POSTED)
  returnDate   DateTime     @default(now())
  subtotal     Decimal      @default(0) @db.Decimal(12, 2)
  discount     Decimal      @default(0) @db.Decimal(12, 2)
  tax          Decimal      @default(0) @db.Decimal(12, 2)
  total        Decimal      @default(0) @db.Decimal(12, 2)
  refundAmount Decimal      @default(0) @db.Decimal(12, 2)
  reason       String?
  notes        String?
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice  Invoice?          @relation(fields: [invoiceId], references: [id])
